---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="post-main">
			<article>
				<a href="/blog" class="back-link">← Volver a proyectos</a>

				{heroImage && (
					<div class="hero-image">
						<Image src={heroImage} alt={title} width={1200} height={400} />
					</div>
				)}

				<div class="prose">
					<header class="post-header">
						<p class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="last-updated-on">
									· Actualizado el <FormattedDate date={updatedDate} />
								</span>
							)}
						</p>
						<h1>{title}</h1>
						{tags && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">#{tag}</span>
								))}
							</div>
						)}
					</header>

					<div class="content">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}
	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--accent);
		font-size: 0.95rem;
		text-decoration: none;
	}
	.back-link:hover { text-decoration: underline; }

	.hero-image {
		max-width: 900px;
		margin: 0 auto 3rem;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 12px 40px rgba(34, 211, 238, 0.15);
	}
	.hero-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	.prose {
		max-width: 720px;
		margin: 0 auto;
		color: rgb(var(--black));
	}

	.post-header {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid rgba(var(--gray-light), 100%);
	}
	.post-header h1 {
		color: var(--accent);
		font-size: 2.4rem;
		line-height: 1.2;
		margin: 0.5rem 0 1rem;
	}
	.date {
		color: rgb(var(--gray));
		font-size: 0.9rem;
		margin: 0;
	}
	.last-updated-on { font-style: italic; }

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 1rem;
	}
	.tag {
		font-size: 0.8rem;
		padding: 0.2rem 0.7rem;
		background: rgba(34, 211, 238, 0.1);
		color: var(--accent);
		border-radius: 999px;
	}

.content {
	font-size: 1.05rem;
	line-height: 1.75;
	color: rgb(var(--black));
}
	.content :global(h2) {
		color: var(--accent);
		font-size: 1.6rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
	}
	.content :global(h3) {
		color: rgb(var(--black));
		font-size: 1.3rem;
		margin-top: 2rem;
	}
	.content :global(p) { margin-bottom: 1.2rem; }
	.content :global(ul),
	.content :global(ol) {
		margin-bottom: 1.2rem;
		padding-left: 1.5rem;
	}
	.content :global(li) { margin-bottom: 0.4rem; }
	.content :global(strong) {
		color: rgb(var(--black));
		font-weight: 600;
	}
	.content :global(code) {
		background: #161b22;
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		font-size: 0.9em;
		color: var(--accent);
	}
	.content :global(pre) {
		background: #161b22;
		padding: 1rem;
		border-radius: 8px;
		overflow-x: auto;
		margin-bottom: 1.5rem;
	}
	.content :global(blockquote) {
		border-left: 3px solid var(--accent);
		padding-left: 1rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: rgb(var(--black));
	}

	@media (max-width: 700px) {
		.post-header h1 { font-size: 1.7rem; }
		.content { font-size: 1rem; }
		.content :global(h2) { font-size: 1.3rem; }
		.content :global(h3) { font-size: 1.15rem; }
		.hero-image { margin-bottom: 2rem; }
	}
</style>