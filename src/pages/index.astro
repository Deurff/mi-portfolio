---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>El D.o.C desarrolla</h1>
				<p class="tagline">Construyendo con IA sin saber programar</p>
				<p class="intro">
					Soy Juan David, médico colombiano viviendo en Salamanca.
					Aquí documento los proyectos que voy construyendo con
					Claude, sin tener conocimientos de programación.
				</p>
				<p class="cta">
					→ <a href="/blog">Ver los proyectos</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		max-width: 720px;
		margin: 4rem auto;
		padding: 0 1rem;
	}
	.hero h1 {
		font-size: 3rem;
		margin-bottom: 0.5rem;
		color: var(--accent);
	}
	.tagline {
		font-size: 1.4rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 2rem;
		font-weight: 300;
	}
	.intro {
		font-size: 1.1rem;
		line-height: 1.6;
		margin-bottom: 2rem;
	}
	.cta {
		font-size: 1.2rem;
	}
	.cta a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 2px solid var(--accent);
	}
	.cta a:hover {
		opacity: 0.8;
	}
	@media (max-width: 600px) {
		.hero h1 { font-size: 2rem; }
		.tagline { font-size: 1.1rem; }
	}
</style>